{"mode":"Text","hardwareTarget":"brain","textContent":"from vex import *\nimport urandom\nimport math\n\n# -------------------------------\n# Robot Configuration\n# -------------------------------\nbrain = Brain()\n\n# Motors (3 per side)\nRight_motor_a = Motor(Ports.PORT1, GearSetting.RATIO_6_1, True)\nRight_motor_b = Motor(Ports.PORT2, GearSetting.RATIO_6_1, True)\nRight_motor_c = Motor(Ports.PORT3, GearSetting.RATIO_6_1, True)\nRight = MotorGroup(Right_motor_a, Right_motor_b, Right_motor_c)\n\nLeft_motor_a = Motor(Ports.PORT11, GearSetting.RATIO_6_1, False)\nLeft_motor_b = Motor(Ports.PORT12, GearSetting.RATIO_6_1, False)\nLeft_motor_c = Motor(Ports.PORT13, GearSetting.RATIO_6_1, False)\nLeft = MotorGroup(Left_motor_a, Left_motor_b, Left_motor_c)\n\n# Controller & IMU\ncontroller_1 = Controller(PRIMARY)\nIMU = Inertial(Ports.PORT10)\n\n# Other motors\nIntake_Motor_Top = Motor(Ports.PORT4, GearSetting.RATIO_18_1, False)\nOuttake = Motor(Ports.PORT5, GearSetting.RATIO_6_1, False)\ndigital_out_a = DigitalOut(brain.three_wire_port.a)\n\nwait(30, MSEC)  # wait for sensors to initialize\n\n# -------------------------------\n# Utility Functions\n# -------------------------------\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n\ninitializeRandomSeed()\n\n# -------------------------------\n# Drive Functions\n# -------------------------------\ndef LeftDrive_Power(power):\n    Left.set_velocity(power, PERCENT)\n    Left.spin(FORWARD)\n\ndef RightDrive_Power(power):\n    Right.set_velocity(power, PERCENT)\n    Right.spin(FORWARD)\n\n# -------------------------------\n# Autonomous Configuration\n# -------------------------------\nAUTO_VELOCITY = 75  # percent\nAUTO_TORQUE = 100   # percent\nWHEEL_DIAMETER = 3.75  # inches\n\ndef configure_auton_motors():\n    Left.set_max_torque(AUTO_TORQUE, PERCENT)\n    Right.set_max_torque(AUTO_TORQUE, PERCENT)\n\n    Left.set_velocity(AUTO_VELOCITY, PERCENT)\n    Right.set_velocity(AUTO_VELOCITY, PERCENT)\n\n# -------------------------------\n# Autonomous Functions\n# -------------------------------\ndef AutonForward(distance_inches: float):\n    wheel_circumference = 3.14159 * WHEEL_DIAMETER\n    degrees_to_spin = (distance_inches / wheel_circumference) * 360\n\n    Left.spin_for(FORWARD, degrees_to_spin, DEGREES, wait=False)\n    Right.spin_for(FORWARD, degrees_to_spin, DEGREES, wait=True)\n\ndef Turn(angle_degrees: float):\n    start = IMU.heading(DEGREES)\n    target = (start + angle_degrees) % 360\n    tolerance = 1.0  # degrees\n\n    while True:\n        current = IMU.heading(DEGREES)\n        error = (target - current + 540) % 360 - 180  # shortest path\n\n        if abs(error) <= tolerance:\n            Left.stop(BRAKE)\n            Right.stop(BRAKE)\n            break\n\n        speed = max(20, min(100, abs(error) * 1.0))\n\n        if error > 0:\n            Left.spin(REVERSE, speed, PERCENT)\n            Right.spin(FORWARD, speed, PERCENT)\n        else:\n            Left.spin(FORWARD, speed, PERCENT)\n            Right.spin(REVERSE, speed, PERCENT)\n\n        wait(10, MSEC)\n\n# -------------------------------\n# Driver Control\n# -------------------------------\ndef ondriver_drivercontrol_0():\n    Left.set_stopping(BRAKE)\n    Right.set_stopping(BRAKE)\n\n    Intake_Motor_Top.set_velocity(100, PERCENT)\n    Outtake.set_velocity(100, PERCENT)\n\n    while True:\n        left_power = controller_1.axis3.position()\n        right_power = controller_1.axis2.position()\n        LeftDrive_Power(left_power)\n        RightDrive_Power(right_power)\n\n        # Intake\n        if controller_1.buttonX.pressing():\n            Intake_Motor_Top.spin(REVERSE)\n        elif controller_1.buttonB.pressing():\n            Intake_Motor_Top.spin(FORWARD)\n        else:\n            Intake_Motor_Top.stop()\n\n        # Outtake\n        if controller_1.buttonR1.pressing():\n            Outtake.spin(FORWARD)\n        elif controller_1.buttonR2.pressing():\n            Outtake.spin(REVERSE)\n        else:\n            Outtake.stop()\n\n        # Pneumatics\n        if controller_1.buttonL1.pressing():\n            digital_out_a.set(True)\n        elif controller_1.buttonL2.pressing():\n            digital_out_a.set(False)\n\n        wait(10, MSEC)\n\n# -------------------------------\n# Autonomous Routine\n# -------------------------------\ndef onauton_autonomous_0():\n    configure_auton_motors()\n\n    Intake_Motor_Top.spin(REVERSE)\n    Outtake.set_velocity(50, PERCENT)\n\n    # Autonomous sequence\n    AutonForward(7.5)\n    Turn(90)      # left turn\n    AutonForward(34)\n    Turn(45)      # left turn\n    AutonForward(14)\n\n    wait(2, SECONDS)\n\n# -------------------------------\n# Competition Setup\n# -------------------------------\ncompetition = Competition(ondriver_drivercontrol_0, onauton_autonomous_0)\n","textLanguage":"python","robotConfig":[{"port":[1,2],"name":"Right","customName":true,"deviceType":"MotorGroup","deviceClass":"motor_group","setting":{"fwd":"forward","rev":"reverse","gear":"ratio6_1","motor_a_reversed":"true","motor_b_reversed":"true"},"triportSourcePort":22},{"port":[3],"name":"RightEx","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse","gear":"ratio6_1"},"triportSourcePort":22},{"port":[11,12],"name":"Left","customName":true,"deviceType":"MotorGroup","deviceClass":"motor_group","setting":{"fwd":"forward","rev":"reverse","gear":"ratio6_1","motor_a_reversed":"false","motor_b_reversed":"false"},"triportSourcePort":22},{"port":[13],"name":"LeftEx","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio6_1"},"triportSourcePort":22},{"port":[],"name":"controller_1","customName":false,"deviceType":"Controller","deviceClass":"controller","setting":{"left":"","leftDir":"false","right":"","rightDir":"false","upDown":"","upDownDir":"false","xB":"","xBDir":"false","drive":"none","id":"primary"},"triportSourcePort":22},{"port":[10],"name":"IMU","customName":true,"deviceType":"Inertial","deviceClass":"inertial","setting":{"id":"partner"},"triportSourcePort":22},{"port":[4],"name":"Intake_Motor_Top","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[5],"name":"Outtake","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio6_1"},"triportSourcePort":22},{"port":[1],"name":"digital_out_a","customName":false,"deviceType":"DigitalOut","deviceClass":"digital_out","setting":{"id":"partner"},"triportSourcePort":22}],"slot":7,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.62.0","minVersion":"4.60.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null},"target":"Physical"}