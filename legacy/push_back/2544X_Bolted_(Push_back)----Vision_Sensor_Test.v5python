{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nLeft_motor_a = Motor(Ports.PORT3, GearSetting.RATIO_6_1, False)\nLeft_motor_b = Motor(Ports.PORT1, GearSetting.RATIO_6_1, False)\nLeft = MotorGroup(Left_motor_a, Left_motor_b)\nRight_motor_a = Motor(Ports.PORT11, GearSetting.RATIO_6_1, True)\nRight_motor_b = Motor(Ports.PORT13, GearSetting.RATIO_6_1, True)\nRight = MotorGroup(Right_motor_a, Right_motor_b)\ncontroller_1 = Controller(PRIMARY)\ninertial_6 = Inertial(Ports.PORT6)\nRightMid = Motor(Ports.PORT2, GearSetting.RATIO_18_1, True)\nLeftMid = Motor(Ports.PORT12, GearSetting.RATIO_6_1, False)\nIntakeMotor = Motor(Ports.PORT20, GearSetting.RATIO_6_1, False)\nOuttakeMotor = Motor(Ports.PORT19, GearSetting.RATIO_36_1, False)\ndigital_out_a = DigitalOut(brain.three_wire_port.a)\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \n# Set random seed \ninitializeRandomSeed()\n\ndef play_vexcode_sound(sound_name):\n    # Helper to make playing sounds from the V5 in VEXcode easier and\n    # keeps the code cleaner by making it clear what is happening.\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n\n#endregion VEXcode Generated Robot Configuration\n\nscreen_precision = 0\nconsole_precision = 0\ncontroller_1_precision = 0\nmyVariable = 0\nIntakeOn = 0\nLeftDegrees = 0\nRightDegrees = 0\nHeadingReal = 0\nTargetHeading = 0\nDIFFERENCEINHEADING = 0\nMotorSpeed = 0\nTrueE = False\n\ndef RightDrive_Power(RightDrive_Power__Power):\n    global Phase_2, my_event, Phase_3, myVariable, IntakeOn, LeftDegrees, RightDegrees, HeadingReal, TargetHeading, DIFFERENCEINHEADING, MotorSpeed, TrueE, screen_precision, console_precision, controller_1_precision\n    Right.set_velocity(RightDrive_Power__Power, PERCENT)\n    RightMid.set_velocity(RightDrive_Power__Power, PERCENT)\n    RightMid.spin(FORWARD)\n    Right.spin(FORWARD)\n\ndef LeftDrive_Power(LeftDrive_Power__Power):\n    global Phase_2, my_event, Phase_3, myVariable, IntakeOn, LeftDegrees, RightDegrees, HeadingReal, TargetHeading, DIFFERENCEINHEADING, MotorSpeed, TrueE, screen_precision, console_precision, controller_1_precision\n    Left.set_velocity(LeftDrive_Power__Power, PERCENT)\n    LeftMid.set_velocity(LeftDrive_Power__Power, PERCENT)\n    LeftMid.spin(FORWARD)\n    Left.spin(FORWARD)\n\ndef Drive_Forward_Number_Of_Inches(Drive_Forward_Number_Of_Inches__Number_Of_Inches):\n    global Phase_2, my_event, Phase_3, myVariable, IntakeOn, LeftDegrees, RightDegrees, HeadingReal, TargetHeading, DIFFERENCEINHEADING, MotorSpeed, TrueE, screen_precision, console_precision, controller_1_precision\n    Left.spin_for(FORWARD, (Drive_Forward_Number_Of_Inches__Number_Of_Inches / 0.028347222), DEGREES)\n    Right.spin_for(FORWARD, (Drive_Forward_Number_Of_Inches__Number_Of_Inches / 0.028347222), DEGREES)\n    RightMid.spin_for(FORWARD, (Drive_Forward_Number_Of_Inches__Number_Of_Inches / 0.028347222), DEGREES)\n    LeftMid.spin_for(FORWARD, (Drive_Forward_Number_Of_Inches__Number_Of_Inches / 0.028347222), DEGREES)\n\ndef TurnInPlace_AngleOfTurn_RightIsNegative(TurnInPlace_AngleOfTurn_RightIsNegative__AngleOfTurn_RightIsNegative):\n    global Phase_2, my_event, Phase_3, myVariable, IntakeOn, LeftDegrees, RightDegrees, HeadingReal, TargetHeading, DIFFERENCEINHEADING, MotorSpeed, TrueE, screen_precision, console_precision, controller_1_precision\n    Left.spin_for(FORWARD, ((0.028347222 * TurnInPlace_AngleOfTurn_RightIsNegative__AngleOfTurn_RightIsNegative) * (360 / (3.25 * 3.14159))), DEGREES)\n    LeftMid.spin_for(FORWARD, ((0.028347222 * TurnInPlace_AngleOfTurn_RightIsNegative__AngleOfTurn_RightIsNegative) * (360 / (3.25 * 3.14159))), DEGREES)\n    Right.spin_for(FORWARD, (((0.028347222 * TurnInPlace_AngleOfTurn_RightIsNegative__AngleOfTurn_RightIsNegative) * (360 / (3.25 * 3.14159))) * -1), DEGREES)\n    RightMid.spin_for(FORWARD, (((0.028347222 * TurnInPlace_AngleOfTurn_RightIsNegative__AngleOfTurn_RightIsNegative) * (360 / (3.25 * 3.14159))) * -1), DEGREES)\n\ndef ondriver_drivercontrol_0():\n    global Phase_2, my_event, Phase_3, myVariable, IntakeOn, LeftDegrees, RightDegrees, HeadingReal, TargetHeading, DIFFERENCEINHEADING, MotorSpeed, TrueE, screen_precision, console_precision, controller_1_precision\n    while True:\n        if controller_1.buttonR1.pressing():\n            digital_out_a.set(True)\n        if controller_1.buttonR2.pressing():\n            digital_out_a.set(False)\n        wait(5, MSEC)\n\ndef when_started1():\n    global Phase_2, my_event, Phase_3, myVariable, IntakeOn, LeftDegrees, RightDegrees, HeadingReal, TargetHeading, DIFFERENCEINHEADING, MotorSpeed, TrueE, screen_precision, console_precision, controller_1_precision\n    pass\n\ndef ondriver_drivercontrol_1():\n    global Phase_2, my_event, Phase_3, myVariable, IntakeOn, LeftDegrees, RightDegrees, HeadingReal, TargetHeading, DIFFERENCEINHEADING, MotorSpeed, TrueE, screen_precision, console_precision, controller_1_precision\n    Left.set_stopping(BRAKE)\n    Right.set_stopping(BRAKE)\n    RightMid.set_stopping(BRAKE)\n    LeftMid.set_stopping(BRAKE)\n    while True:\n        LeftDrive_Power(controller_1.axis3.position())\n        RightDrive_Power(controller_1.axis2.position())\n        wait(5, MSEC)\n\ndef ondriver_drivercontrol_2():\n    global Phase_2, my_event, Phase_3, myVariable, IntakeOn, LeftDegrees, RightDegrees, HeadingReal, TargetHeading, DIFFERENCEINHEADING, MotorSpeed, TrueE, screen_precision, console_precision, controller_1_precision\n    while True:\n        controller_1.screen.print(str(Right.temperature(PERCENT)) + str(\"____Right Motors\"))\n        controller_1.screen.print(str(Left.temperature(PERCENT)) + str(\"____Left Motors\"))\n        wait(5, MSEC)\n\ndef ondriver_drivercontrol_3():\n    global Phase_2, my_event, Phase_3, myVariable, IntakeOn, LeftDegrees, RightDegrees, HeadingReal, TargetHeading, DIFFERENCEINHEADING, MotorSpeed, TrueE, screen_precision, console_precision, controller_1_precision\n    IntakeOn = 0\n    while True:\n        if controller_1.buttonX.pressing():\n            IntakeOn = 1\n        if controller_1.buttonY.pressing():\n            IntakeOn = 0\n        if controller_1.buttonB.pressing():\n            IntakeOn = -1\n        wait(5, MSEC)\n\ndef ondriver_drivercontrol_4():\n    global Phase_2, my_event, Phase_3, myVariable, IntakeOn, LeftDegrees, RightDegrees, HeadingReal, TargetHeading, DIFFERENCEINHEADING, MotorSpeed, TrueE, screen_precision, console_precision, controller_1_precision\n    OuttakeMotor.set_velocity(100, PERCENT)\n    while True:\n        if controller_1.buttonL1.pressing():\n            OuttakeMotor.spin(REVERSE)\n        else:\n            OuttakeMotor.stop()\n        wait(5, MSEC)\n\ndef ondriver_drivercontrol_5():\n    global Phase_2, my_event, Phase_3, myVariable, IntakeOn, LeftDegrees, RightDegrees, HeadingReal, TargetHeading, DIFFERENCEINHEADING, MotorSpeed, TrueE, screen_precision, console_precision, controller_1_precision\n    while True:\n        IntakeMotor.set_velocity((IntakeOn * 100), PERCENT)\n        IntakeMotor.spin(FORWARD)\n        wait(5, MSEC)\n\n# ----- SAFE AUTONOMOUS -----\ndef onauton_autonomous_0_safe():\n    global Phase_2, my_event, Phase_3, myVariable, IntakeOn, LeftDegrees, RightDegrees, HeadingReal, TargetHeading, DIFFERENCEINHEADING, MotorSpeed, TrueE, screen_precision, console_precision, controller_1_precision\n    \n    # Calibrate inertial sensor first\n    inertial_6.calibrate()\n    while inertial_6.is_calibrating():\n        wait(2,SECONDS)\n    \n    # Set target heading\n    TargetHeading = 90\n\n    # Loop until heading reaches target (with tolerance)\n    tolerance = 2  # degrees\n    while True:\n        HeadingReal = inertial_6.heading(DEGREES)\n        DIFFERENCEINHEADING = TargetHeading - HeadingReal\n        \n        # Stop if within tolerance\n        if abs(DIFFERENCEINHEADING) <= tolerance:\n            OuttakeMotor.stop()\n            break\n        \n        # Calculate proportional motor speed\n        MotorSpeed = 0.3 * abs(DIFFERENCEINHEADING)\n        MotorSpeed = min(MotorSpeed, 100)  # clamp to 100%\n        \n        # Spin motor toward target\n        if DIFFERENCEINHEADING > 0:\n            OuttakeMotor.set_velocity(MotorSpeed, PERCENT)\n            OuttakeMotor.spin(FORWARD)\n        else:\n            OuttakeMotor.set_velocity(MotorSpeed, PERCENT)\n            OuttakeMotor.spin(REVERSE)\n        \n        wait(5, MSEC)\n\n# create a function for handling the starting and stopping of all autonomous tasks\ndef vexcode_auton_function():\n    # Start the safe autonomous task\n    auton_task = Thread(onauton_autonomous_0_safe)\n    \n    # Wait for autonomous period to end\n    while( competition.is_autonomous() and competition.is_enabled() ):\n        wait(10, MSEC)\n    \n    # Stop the autonomous task safely\n    auton_task.stop()\n\n# driver function remains unchanged\ndef vexcode_driver_function():\n    # Start the driver control tasks\n    driver_control_task_0 = Thread( ondriver_drivercontrol_0 )\n    driver_control_task_1 = Thread( ondriver_drivercontrol_1 )\n    driver_control_task_2 = Thread( ondriver_drivercontrol_2 )\n    driver_control_task_3 = Thread( ondriver_drivercontrol_3 )\n    driver_control_task_4 = Thread( ondriver_drivercontrol_4 )\n    driver_control_task_5 = Thread( ondriver_drivercontrol_5 )\n\n    # wait for the driver control period to end\n    while( competition.is_driver_control() and competition.is_enabled() ):\n        wait( 10, MSEC )\n    \n    # Stop the driver control tasks\n    driver_control_task_0.stop()\n    driver_control_task_1.stop()\n    driver_control_task_2.stop()\n    driver_control_task_3.stop()\n    driver_control_task_4.stop()\n    driver_control_task_5.stop()\n\n# register the competition functions\ncompetition = Competition( vexcode_driver_function, vexcode_auton_function )\n\nwhen_started1()\n","textLanguage":"python","robotConfig":[{"port":[3,1],"name":"Left","customName":true,"deviceType":"MotorGroup","deviceClass":"motor_group","setting":{"fwd":"forward","rev":"reverse","gear":"ratio6_1","motor_a_reversed":"false","motor_b_reversed":"false"},"triportSourcePort":22},{"port":[11,13],"name":"Right","customName":true,"deviceType":"MotorGroup","deviceClass":"motor_group","setting":{"fwd":"forward","rev":"reverse","gear":"ratio6_1","motor_a_reversed":"true","motor_b_reversed":"true"},"triportSourcePort":22},{"port":[],"name":"controller_1","customName":false,"deviceType":"Controller","deviceClass":"controller","setting":{"left":"","leftDir":"false","right":"","rightDir":"false","upDown":"","upDownDir":"false","xB":"","xBDir":"false","drive":"none","id":"primary"},"triportSourcePort":22},{"port":[6],"name":"inertial_6","customName":false,"deviceType":"Inertial","deviceClass":"inertial","setting":{"id":"partner"},"triportSourcePort":22},{"port":[2],"name":"RightMid","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[12],"name":"LeftMid","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio6_1"},"triportSourcePort":22},{"port":[20],"name":"IntakeMotor","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio6_1"},"triportSourcePort":22},{"port":[19],"name":"OuttakeMotor","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio36_1"},"triportSourcePort":22},{"port":[1],"name":"digital_out_a","customName":false,"deviceType":"DigitalOut","deviceClass":"digital_out","setting":{"id":"partner"},"triportSourcePort":22}],"slot":6,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.62.0","minVersion":"4.60.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null},"target":"Physical"}