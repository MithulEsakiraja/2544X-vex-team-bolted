{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nRight_motor_a = Motor(Ports.PORT1, GearSetting.RATIO_6_1, True)\nRight_motor_b = Motor(Ports.PORT2, GearSetting.RATIO_6_1, True)\nRight = MotorGroup(Right_motor_a, Right_motor_b)\nRightEx = Motor(Ports.PORT3, GearSetting.RATIO_6_1, True)\nLeft_motor_a = Motor(Ports.PORT11, GearSetting.RATIO_6_1, False)\nLeft_motor_b = Motor(Ports.PORT12, GearSetting.RATIO_6_1, False)\nLeft = MotorGroup(Left_motor_a, Left_motor_b)\nLeftEx = Motor(Ports.PORT13, GearSetting.RATIO_6_1, False)\ncontroller_1 = Controller(PRIMARY)\nIMU = Inertial(Ports.PORT10)\nIntake_Motor_Top = Motor(Ports.PORT4, GearSetting.RATIO_6_1, False)\ndigital_out_a = DigitalOut(brain.three_wire_port.a)\nOuttake = Motor(Ports.PORT5, GearSetting.RATIO_6_1, False)\n\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \n# Set random seed \ninitializeRandomSeed()\n\n\ndef play_vexcode_sound(sound_name):\n    # Helper to make playing sounds from the V5 in VEXcode easier and\n    # keeps the code cleaner by making it clear what is happening.\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n\n#endregion VEXcode Generated Robot Configuration\n\nmyVariable = 0\n\ndef LeftDrive_Power(LeftDrive_Power__Power):\n    global myVariable\n    Left.set_velocity(LeftDrive_Power__Power, PERCENT)\n    LeftEx.set_velocity(LeftDrive_Power__Power, PERCENT)\n    Left.spin(FORWARD)\n    LeftEx.spin(FORWARD)\n\ndef RightDrive_Power(RightDrive_Power__Power):\n    global myVariable\n    Right.set_velocity(RightDrive_Power__Power, PERCENT)\n    RightEx.set_velocity(RightDrive_Power__Power, PERCENT)\n    Right.spin(FORWARD)\n    RightEx.spin(FORWARD)\n\ndef AutonForward_Inches_Number(distance_inches):\n    # Conversion factor: inches to motor degrees\n    degrees_to_spin = distance_inches / 0.028347222  # adjust this based on your wheel specs\n    \n    # Start both motors at the same time\n    Right.spin_for(FORWARD, degrees_to_spin, DEGREES, wait=False)\n    RightEx.spin_for(FORWARD, degrees_to_spin, DEGREES, wait=False)\n    LeftEx.spin_for(FORWARD, degrees_to_spin, DEGREES, wait=False)\n    Left.spin_for(FORWARD, degrees_to_spin, DEGREES, wait=True)  # wait=True ensures function waits until done\ndef AutonTurn(Degrees_Of_rotation):\n    Left_degrees_to_spin = 0.028347222 * Degrees_Of_rotation * (360 / (3.25 * 3.14159))\n    Right_degrees_to_spin = (0.028347222 * Degrees_Of_rotation * (360 / (3.25 * 3.14159))) * -1\n\n    Left.spin_for(FORWARD,Left_degrees_to_spin, DEGREES, wait=False)\n    LeftEx.spin_for(FORWARD,Left_degrees_to_spin, DEGREES, wait=False)\n    Right.spin_for(FORWARD,Right_degrees_to_spin, DEGREES, wait=False)\n    RightEx.spin_for(FORWARD,Right_degrees_to_spin, DEGREES, wait=True)\n    pass\n\ndef when_started1():\n    global myVariable\n    pass\n\ndef ondriver_drivercontrol_0():\n    # Set intake motor speed\n    Intake_Motor_Top.set_velocity(100, PERCENT)\n    Outtake.set_velocity(100, PERCENT)\n\n    # Set drive motors to brake when stopping\n    Right.set_stopping(BRAKE)\n    Left.set_stopping(BRAKE)\n    RightEx.set_stopping(BRAKE)\n    LeftEx.set_stopping(BRAKE)\n\n    while True:\n        # Drive controls\n        LeftDrive_Power(controller_1.axis3.position())\n        RightDrive_Power(controller_1.axis2.position())\n   # Intake controls\n        if controller_1.buttonX.pressing():\n            Intake_Motor_Top.spin(REVERSE)\n        elif controller_1.buttonB.pressing():\n            Intake_Motor_Top.spin(FORWARD)\n        elif controller_1.buttonY.pressing():\n            Intake_Motor_Top.stop()\n\n        if controller_1.buttonL2.pressing():\n            digital_out_a.set(True)\n        elif controller_1.buttonL1.pressing():\n            digital_out_a.set(False)\n            pass\n        if controller_1.buttonR1.pressing():\n            Outtake.spin(FORWARD)\n        else:\n            Outtake.stop()\n            pass\n        wait(5, MSEC)\ndef driver_control:\n    brain.screen.print(\"Intake Heat \"(Intake_Motor_Top.temperature(percent))\n    pass\n\ndef onauton_autonomous_0():/\n    global myVariable\n    Intake_Motor_Top.set_velocity(100,PERCENT)\n    Outtake.set_velocity(100,PERCENT)\n    Right.set_velocity(100, PERCENT)\n    Left.set_velocity(100, PERCENT)\n    RightEx.set_velocity(100, PERCENT)\n    LeftEx.set_velocity(100, PERCENT)\n    Intake_Motor_Top.spin(REVERSE)\n    AutonForward_Inches_Number(7.5)\n    AutonTurn(90)\n    AutonForward_Inches_Number(34)\n    AutonTurn(45)\n    AuronForward_Inches_Number(14)\n    Intake_Motor_Top.spin(FORWARD)\n    Intake_Motor_Top.stop()\n    AutonForward_Inches_Number(-55)\n    AutonTurn(135)\n    digital_out_a(True)\n    Intake_Motor_Top.spin(REVERSE)\n    AutonForward_Inches_Number(14)\n    wait(2,SECONDS)\n    AutonForward_Inches_Number(-34)\n    Outtake.spin(FORWARD)\n    brain.program_stop()\n    \n\n\n\n# create a function for handling the starting and stopping of all autonomous tasks\ndef vexcode_auton_function():\n    # Start the autonomous control tasks\n    auton_task_0 = Thread( onauton_autonomous_0 )\n    # wait for the driver control period to end\n    while( competition.is_autonomous() and competition.is_enabled() ):\n        # wait 10 milliseconds before checking again\n        wait( 10, MSEC )\n    # Stop the autonomous control tasks\n    auton_task_0.stop()\n\ndef vexcode_driver_function():\n    # Start the driver control tasks\n    driver_control_task_0 = Thread( ondriver_drivercontrol_0 )\n\n    # wait for the driver control period to end\n    while( competition.is_driver_control() and competition.is_enabled() ):\n        # wait 10 milliseconds before checking again\n        wait( 10, MSEC )\n    # Stop the driver control tasks\n    driver_control_task_0.stop()\n\n\n# register the competition functions\ncompetition = Competition( vexcode_driver_function, vexcode_auton_function )\n\nwhen_started1()\n","textLanguage":"python","robotConfig":[{"port":[1,2],"name":"Right","customName":true,"deviceType":"MotorGroup","deviceClass":"motor_group","setting":{"fwd":"forward","rev":"reverse","gear":"ratio6_1","motor_a_reversed":"true","motor_b_reversed":"true"},"triportSourcePort":22},{"port":[3],"name":"RightEx","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse","gear":"ratio6_1"},"triportSourcePort":22},{"port":[11,12],"name":"Left","customName":true,"deviceType":"MotorGroup","deviceClass":"motor_group","setting":{"fwd":"forward","rev":"reverse","gear":"ratio6_1","motor_a_reversed":"false","motor_b_reversed":"false"},"triportSourcePort":22},{"port":[13],"name":"LeftEx","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio6_1"},"triportSourcePort":22},{"port":[],"name":"controller_1","customName":false,"deviceType":"Controller","deviceClass":"controller","setting":{"left":"","leftDir":"false","right":"","rightDir":"false","upDown":"","upDownDir":"false","xB":"","xBDir":"false","drive":"none","id":"primary"},"triportSourcePort":22},{"port":[10],"name":"IMU","customName":true,"deviceType":"Inertial","deviceClass":"inertial","setting":{"id":"partner"},"triportSourcePort":22},{"port":[4],"name":"Intake_Motor_Top","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio6_1"},"triportSourcePort":22},{"port":[1],"name":"digital_out_a","customName":false,"deviceType":"DigitalOut","deviceClass":"digital_out","setting":{"id":"partner"},"triportSourcePort":22},{"port":[5],"name":"Outtake","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio6_1"},"triportSourcePort":22}],"slot":0,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.62.0","minVersion":"4.60.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null},"target":"Physical"}