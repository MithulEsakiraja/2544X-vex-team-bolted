{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nLeft_motor_a = Motor(Ports.PORT3, GearSetting.RATIO_6_1, False)\nLeft_motor_b = Motor(Ports.PORT1, GearSetting.RATIO_6_1, False)\nLeft = MotorGroup(Left_motor_a, Left_motor_b)\n\nRight_motor_a = Motor(Ports.PORT2, GearSetting.RATIO_6_1, True)\nRight_motor_b = Motor(Ports.PORT4, GearSetting.RATIO_6_1, True)\nRight = MotorGroup(Right_motor_a, Right_motor_b)\n\ncontroller_1 = Controller(PRIMARY)\ninertial_6 = Inertial(Ports.PORT6)\n\nRightMid = Motor(Ports.PORT9, GearSetting.RATIO_6_1, True)\nLeftMid = Motor(Ports.PORT10, GearSetting.RATIO_6_1, False)\n\nIntakeMotor = Motor(Ports.PORT20, GearSetting.RATIO_6_1, False)\nOuttakeMotor = Motor(Ports.PORT19, GearSetting.RATIO_36_1, False)\n\ndigital_out_a = DigitalOut(brain.three_wire_port.a)\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n\ninitializeRandomSeed()\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n#endregion VEXcode Generated Robot Configuration\n\nscreen_precision = 0\nconsole_precision = 0\ncontroller_1_precision = 0\nmyVariable = 0\nIntakeOn = 0\nLeftDegrees = 0\nRightDegrees = 0\n\n\n# --------------------------------------------------------------------\n# Helper functions\n# --------------------------------------------------------------------\ndef RightDrive_Power(power):\n    Right.set_velocity(power, PERCENT)\n    RightMid.set_velocity(power, PERCENT)\n    RightMid.spin(FORWARD)\n    Right.spin(FORWARD)\n\ndef LeftDrive_Power(power):\n    Left.set_velocity(power, PERCENT)\n    LeftMid.set_velocity(power, PERCENT)\n    LeftMid.spin(FORWARD)\n    Left.spin(FORWARD)\n\ndef Drive_Forward_Number_Of_Inches(inches):\n    deg = inches / 0.028347222\n    Left.spin_for(FORWARD, deg, DEGREES)\n    Right.spin_for(FORWARD, deg, DEGREES)\n    RightMid.spin_for(FORWARD, deg, DEGREES)\n    LeftMid.spin_for(FORWARD, deg, DEGREES)\n\ndef TurnInPlace_AngleOfTurn_RightIsNegative(angle):\n    base = (0.028347222 * angle) * (360 / (3.25 * 3.14159))\n    Left.spin_for(FORWARD, base, DEGREES)\n    LeftMid.spin_for(FORWARD, base, DEGREES)\n    Right.spin_for(FORWARD, -base, DEGREES)\n    RightMid.spin_for(FORWARD, -base, DEGREES)\n\n\n# --------------------------------------------------------------------\n# Driver control tasks\n# --------------------------------------------------------------------\ndef ondriver_drivercontrol_0():\n    while True:\n        if controller_1.buttonR1.pressing():\n            digital_out_a.set(True)\n        if controller_1.buttonR2.pressing():\n            digital_out_a.set(False)\n        wait(5, MSEC)\n\ndef ondriver_drivercontrol_1():\n    Left.set_stopping(BRAKE)\n    Right.set_stopping(BRAKE)\n    RightMid.set_stopping(BRAKE)\n    LeftMid.set_stopping(BRAKE)\n    while True:\n        LeftDrive_Power(controller_1.axis3.position())\n        RightDrive_Power(controller_1.axis2.position())\n        wait(5, MSEC)\n\ndef ondriver_drivercontrol_2():\n    while True:\n        controller_1.screen.print(str(Right.temperature(PERCENT)) + \"____Right Motors\")\n        controller_1.screen.print(str(Left.temperature(PERCENT)) + \"____Left Motors\")\n        wait(5, MSEC)\n\ndef ondriver_drivercontrol_3():\n    global IntakeOn\n    IntakeOn = 0\n    while True:\n        if controller_1.buttonX.pressing():\n            IntakeOn = 1\n        if controller_1.buttonY.pressing():\n            IntakeOn = 0\n        if controller_1.buttonB.pressing():\n            IntakeOn = -1\n        wait(5, MSEC)\n\ndef ondriver_drivercontrol_4():\n    OuttakeMotor.set_velocity(100, PERCENT)\n    while True:\n        if controller_1.buttonL1.pressing():\n            OuttakeMotor.spin(REVERSE)\n        else:\n            OuttakeMotor.stop()\n        wait(5, MSEC)\n\ndef ondriver_drivercontrol_5():\n    while True:\n        IntakeMotor.set_velocity(IntakeOn * 100, PERCENT)\n        IntakeMotor.spin(FORWARD)\n        wait(5, MSEC)\n\n\n# --------------------------------------------------------------------\n# AUTONOMOUS — ALL FIXED + MOTOR TEST\n# --------------------------------------------------------------------\ndef onauton_autonomous_all():\n\n    # ----------------------------------------------------\n    # 0 — MOTOR TEST: spin ONLY RightMid for 3 seconds\n    # ----------------------------------------------------\n    brain.screen.print(\"TEST: RightMid Spin\")\n    RightMid.set_velocity(50, PERCENT)\n    RightMid.spin(FORWARD)\n    wait(3, SECONDS)\n    RightMid.stop()\n    brain.screen.clear_screen()\n\n    # ----------------------------------------------------\n    # 1 — Inertial setup\n    # ----------------------------------------------------\n    inertial_6.calibrate()\n    while inertial_6.is_calibrating():\n        wait(10, MSEC)\n\n    inertial_6.set_heading(0, DEGREES)\n\n    RightMid.set_velocity(50, PERCENT)\n\n    # Turn until heading >= 90°\n    while inertial_6.heading(DEGREES) < 90:\n        RightMid.spin(FORWARD)\n\n    RightMid.stop()\n\n    # ----------------------------------------------------\n    # 2 — Your original autonomous routine\n    # ----------------------------------------------------\n    IntakeMotor.spin(FORWARD)\n    wait(0.3, SECONDS)\n    Drive_Forward_Number_Of_Inches(7.5)\n    TurnInPlace_AngleOfTurn_RightIsNegative(90)\n    Drive_Forward_Number_Of_Inches(34)\n    TurnInPlace_AngleOfTurn_RightIsNegative(45)\n    IntakeMotor.stop()\n    IntakeMotor.spin(REVERSE)\n    OuttakeMotor.spin(FORWARD)\n    Drive_Forward_Number_Of_Inches(-50)\n    IntakeMotor.stop()\n    OuttakeMotor.stop()\n    TurnInPlace_AngleOfTurn_RightIsNegative(-225)\n    digital_out_a.set(True)\n    Drive_Forward_Number_Of_Inches(12)\n    IntakeMotor.spin(FORWARD)\n    Drive_Forward_Number_Of_Inches(-12)\n    digital_out_a.set(False)\n    Drive_Forward_Number_Of_Inches(-30)\n    OuttakeMotor.spin(REVERSE)\n    brain.screen.set_fill_color(Color.BLUE)\n    brain.screen.set_pen_color(Color.RED)\n    brain.screen.set_font(FontType.PROP60)\n    brain.screen.print(\"Autonomous Executed\")\n\n\n# --------------------------------------------------------------------\n# Competition wrapper (UPDATED — NO THREADS)\n# --------------------------------------------------------------------\ndef vexcode_auton_function():\n    onauton_autonomous_all()\n\ndef vexcode_driver_function():\n    driver_control_task_0 = Thread(ondriver_drivercontrol_0)\n    driver_control_task_1 = Thread(ondriver_drivercontrol_1)\n    driver_control_task_2 = Thread(ondriver_drivercontrol_2)\n    driver_control_task_3 = Thread(ondriver_drivercontrol_3)\n    driver_control_task_4 = Thread(ondriver_drivercontrol_4)\n    driver_control_task_5 = Thread(ondriver_drivercontrol_5)\n\n    while competition.is_driver_control() and competition.is_enabled():\n        wait(10, MSEC)\n\n    driver_control_task_0.stop()\n    driver_control_task_1.stop()\n    driver_control_task_2.stop()\n    driver_control_task_3.stop()\n    driver_control_task_4.stop()\n    driver_control_task_5.stop()\n\ncompetition = Competition(vexcode_driver_function, vexcode_auton_function)\n","textLanguage":"python","robotConfig":[],"slot":2,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.62.0","minVersion":"4.60.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null},"target":"Physical"}